# KAVACH-ULTRA 2026 — .env Template
# Copy to .env and fill in your keys

# ─── BINANCE FUTURES ────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true   # Set to false for LIVE trading

# ─── HYPERLIQUID ────────────────────
HYPERLIQUID_ADDRESS=0xYourEVMWalletAddress
HYPERLIQUID_SECRET=your_private_key_here

# ─── OPENAI ─────────────────────────
OPENAI_API_KEY=sk-...

# ─── NEWS SOURCES ───────────────────
CRYPTOPANIC_API_KEY=your_cryptopanic_key
TWITTER_BEARER_TOKEN=your_twitter_bearer_token   # Optional

# ─── TELEGRAM ───────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id   # Get from @userinfobot

# ─── CAPITAL ────────────────────────
TOTAL_CAPITAL_USDT=5000